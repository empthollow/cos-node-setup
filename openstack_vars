release=bobcat
archetype="controller"
controllerip=172.22.3.21
computeip=172.22.3.22
blockstoreip=172.22.3.23
objectstoreip=172.22.3.24
myuser=stacked

# keystone
KEYSTONE_V3_ENDPOINT="http://controller:5000/v3"

# cinder
# cinder storage device only - i.e. sdb
cinderdev=vda
# cinder controller ip
cinderctrlip=$controllerip

# set allowed hosts to access horizon - comma separated
hzallowedhosts="*"
# Time Zone Abbr: https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
srvtz=CST

# neutron
integrationbridge=br-int
tunnelbridge = br-tun
provideriface=br-ex
overlayip=$controllerip
providercidrip=172.22.2.21/24

#swift
storagedev1=/dev/sdb
storagedev2=/dev/sdc
# space-separated list of swift storage node IPs for ring creation
swiftstoragenodes="$objectstoreip"
# Swift replica count (3 for production, 2 for testing with single node)
swift_replicas=2
# Swift hash values (will be auto-generated if not set)
# IMPORTANT: Keep these secret and never change them after initial setup
SWIFT_HASH_PATH_SUFFIX=""
SWIFT_HASH_PATH_PREFIX=""


